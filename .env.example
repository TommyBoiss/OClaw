# OClaw Configuration
# Copy this file to .env and customize as needed

# Provider Selection
PROVIDER=ollama

# Ollama Settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=kimi-k2.5:cloud

# OpenAI Settings
OPENAI_HOST=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key

# Agent Settings
MAX_ITERATIONS=5

# Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Worker Settings
NUM_WORKERS=4
WORKER_TIMEOUT=300
